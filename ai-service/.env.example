# Google Gemini API key — get one at https://ai.google.dev
GEMINI_API_KEY=

# Required in production: clients must send this in X-API-Key header for /analyze and /check-duplicate
AI_SERVICE_API_KEY=

# Comma-separated allowed origins (e.g. https://yourapp.vercel.app,http://localhost:3000). Empty = no CORS.
CORS_ORIGINS=

# Server
PORT=8001
