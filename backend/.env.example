# Server
PORT=5000


MONGODB_URI=

# JWT — use a long random string in production
JWT_SECRET=
JWT_EXPIRES_IN=7d

# AI service (optional; for duplicate check and analyze-photo proxy). Set both when ai-service is deployed.
AI_SERVICE_URL=
AI_SERVICE_API_KEY=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=100



